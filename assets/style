/* ── Customização de scrollbar ──────────── */

/* Largura da scrollbar em navegadores webkit (Chrome, Safari) */
::-webkit-scrollbar { 
  width: 6px;                           /* Scrollbar fina (6px) */
}

/* Fundo da scrollbar track */
::-webkit-scrollbar-track { 
  background: transparent;              /* Transparente (invisível por padrão) */
}

/* Estilo do thumb (parte que se move) */
::-webkit-scrollbar-thumb { 
  background: #C8CEEB;                  /* Cinza azulado */
  border-radius: 99px;                  /* Cantos muito arredondados */
}

/* Estilo do thumb ao passar o mouse */
::-webkit-scrollbar-thumb:hover { 
  background: var(--accent);            /* Muda para azul (accent) */
}

/* ── Ajustes responsivos para telas pequenas ── */

/* Aplica quando tela tem 900px ou menos de largura */
@media (max-width: 900px) {
  #sidebar { 
    width: 64px;                        /* Sidebar se torna colapsada (apenas ícones) */
  }
  
  .nav-item span { 
    display: none;                      /* Esconde textos dos itens de navegação */
  }
  
  /* Esconde elementos de texto não essenciais na sidebar colapsada */
  .sidebar-logo-title, 
  .sidebar-logo-sub, 
  .nav-section-label, 
  .sidebar-footer { 
    display: none;                      /* Remove do fluxo de layout */
  }
  
  #page-content { 
    padding: 24px 20px;                 /* Reduz padding do conteúdo para telas pequenas */
  }
}
